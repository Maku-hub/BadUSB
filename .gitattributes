# Normalize line endings to LF across the whole repository.
# The badusb.ino parser handles LF, CRLF and CR, but we keep payloads and
# config files on the SD card in LF for consistency.

# Default: detect text files and normalize to LF in the repo.
* text=auto eol=lf

# Project sources and text files - always LF.
*.ino   text eol=lf
*.h     text eol=lf
*.cpp   text eol=lf
*.txt   text eol=lf
*.cfg   text eol=lf
*.md    text eol=lf

# Binary files - do not touch line endings.
*.png   binary
*.jpg   binary
*.bin   binary
*.hex   binary
